# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/your_database_name

# JWT signing secret — generate a long random string for production
SECRET_KEY=change_this_to_a_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Groq AI — https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# YouTube Data API (optional — powers Document Tutor video recommendations)
YOUTUBE_API_KEY=your_youtube_api_key

# File storage
UPLOAD_DIR=uploads
RESUME_UPLOAD_DIR=resume_uploads
MAX_FILE_SIZE_MB=10

# Comma-separated list of frontend origins allowed to call this API (CORS).
# Local dev works out of the box; add your real domain(s) in production, e.g.:
# ALLOWED_ORIGINS=https://app.yourdomain.com,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
